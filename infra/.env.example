###############################################################################
# fin-rag — environment template
# Copy to `.env` and fill in. NEVER commit the populated `.env`.
# In production, prefer Dokploy/Docker secrets over file-based env vars.
###############################################################################

# --- image tag (set by CI) ---
IMAGE_TAG=latest

# --- ports (host side) ---
APP_PORT=3000
API_PORT=8000
POSTGRES_PORT=5432
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
LLM_PORT=8001
GRAFANA_PORT=3001
PROMETHEUS_PORT=9090

# --- postgres ---
POSTGRES_USER=finrag
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=finrag

# --- minio ---
MINIO_ROOT_USER=finrag
MINIO_ROOT_PASSWORD=change-me-strong-password
MINIO_BUCKET=rawfiles

# --- auth ---
# 32+ random bytes, base64
JWT_SECRET=replace-with-`openssl rand -base64 48`
JWT_TTL_HOURS=24

# --- LLM (decide based on Section 0 hardware gate) ---
# Any OpenAI-compatible endpoint works — only LLM_BASE_URL/LLM_API_KEY/LLM_MODEL change.
#
# 1) OpenAI (default):
#      LLM_PROVIDER=openai
#      LLM_BASE_URL=https://api.openai.com/v1
#      LLM_MODEL=gpt-4o-mini
#
# 2) OpenRouter (cheap multi-provider gateway):
#      LLM_PROVIDER=openai
#      LLM_BASE_URL=https://openrouter.ai/api/v1
#      LLM_API_KEY=sk-or-...
#      LLM_MODEL=meta-llama/llama-3.1-70b-instruct
#
# 3) Ollama (self-hosted, no GPU required for small models):
#      Run `ollama serve` on the host, then:
#      LLM_PROVIDER=openai
#      LLM_BASE_URL=http://host.docker.internal:11434/v1
#      LLM_API_KEY=ollama   # any non-empty string
#      LLM_MODEL=llama3.1:8b-instruct
#
# 4) vLLM in-cluster (LLM_PROVIDER=local, requires NVIDIA GPU >=12GB VRAM):
#      Use `make up-local`; the api will reach the llm container at
#      http://llm:8001/v1.
#
# 5) Azure OpenAI / Bedrock / Groq: same shape, swap base URL + key.
LLM_PROVIDER=openai
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-replace-me
LLM_MODEL=gpt-4o-mini

# --- vLLM-only (LLM_PROVIDER=local) ---
VLLM_MODEL=mistralai/Mistral-7B-Instruct-v0.2
HUGGING_FACE_HUB_TOKEN=

# --- embeddings / rerank ---
EMBED_MODEL=BAAI/bge-base-en-v1.5
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# --- worker ---
WORKER_POLL_INTERVAL=5

# --- next.js ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
# Used by /admin/observability to embed the Grafana dashboard:
NEXT_PUBLIC_GRAFANA_BASE_URL=http://localhost:3001

# --- observability ---
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
LOG_LEVEL=INFO
